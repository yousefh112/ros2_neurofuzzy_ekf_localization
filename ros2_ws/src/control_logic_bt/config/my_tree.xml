<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="Untitled">
    <Fallback>
      <Sequence>
        <CheckGPS gps_online="{gps_online}"/>
        <SetFusionWeights a1="0.5"
                          a2="0.5"
                          a3="0"/>
      </Sequence>
      <Sequence>
        <SetFusionWeights a1="0"
                          a2="0"
                          a3="1"/>
      </Sequence>
    </Fallback>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="CheckGPS"
               editable="true">
      <input_port name="gps_online"
                  type="bool"/>
    </Condition>
    <Action ID="SetFusionWeights"
            editable="true">
      <input_port name="a1"
                  type="double"/>
      <input_port name="a2"
                  type="double"/>
      <input_port name="a3"
                  type="double"/>
    </Action>
  </TreeNodesModel>

</root>
